@model Real_Estate_App.Models.Property

@{
    ViewData["Title"] = "Delete Property";
}

<h1>Delete Property</h1>
<h3>Are you sure you want to delete this property?</h3>
<hr />

<div class="col-md-8">
    <dl class="row">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PropertyName)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PropertyName)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PropertyAddress)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PropertyAddress)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PropertyType)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PropertyType)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Price)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Price)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PropertyBedrooms)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PropertyBedrooms)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PropertyBathrooms)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PropertyBathrooms)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="PropertyId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
