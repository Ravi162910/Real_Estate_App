@model IEnumerable<Real_Estate_App.Models.Transaction>

@{
    ViewData["Title"] = "Purchase Approval Queue";
    var currentFilter = ViewData["CurrentFilter"] as string ?? Real_Estate_App.Models.Transaction.StatusPending;
    var pendingCount = (int)(ViewData["PendingCount"] ?? 0);
    var approvedCount = (int)(ViewData["ApprovedCount"] ?? 0);
    var rejectedCount = (int)(ViewData["RejectedCount"] ?? 0);

    string TabClass(string filter) =>
        currentFilter == filter ? "nav-link active" : "nav-link";
}

<h1>Transaction Admin Dashboard</h1>
<p class="text-muted">Review buyer purchase requests. Approving a request marks the property as sold and notifies the buyer by email.</p>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}
@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="@TabClass(Real_Estate_App.Models.Transaction.StatusPending)"
           asp-action="Index" asp-route-status="@Real_Estate_App.Models.Transaction.StatusPending">
            Pending <span class="badge bg-warning text-dark">@pendingCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="@TabClass(Real_Estate_App.Models.Transaction.StatusApproved)"
           asp-action="Index" asp-route-status="@Real_Estate_App.Models.Transaction.StatusApproved">
            Approved <span class="badge bg-success">@approvedCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="@TabClass(Real_Estate_App.Models.Transaction.StatusRejected)"
           asp-action="Index" asp-route-status="@Real_Estate_App.Models.Transaction.StatusRejected">
            Rejected <span class="badge bg-danger">@rejectedCount</span>
        </a>
    </li>
</ul>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No <strong>@currentFilter.ToLower()</strong> transactions to show.
    </div>
}
else
{
    <table class="table table-striped table-hover border-3 shadow">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th><i class="bi bi-house"></i> Property</th>
                <th><i class="bi bi-geo-alt"></i> Address</th>
                <th><i class="bi bi-person" style="vertical-align:middle"></i> Buyer</th>
                <th><i class="bi bi-envelope" style="vertical-align:middle"></i> Email</th>
                <th><i class="bi bi-currency-dollar"></i> Price</th>
                <th><i class="bi bi-calendar"></i> Requested</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.TransactionId</td>
                    <td>@item.Property?.PropertyName</td>
                    <td>@item.Property?.PropertyAddress</td>
                    <td>@item.BuyerName</td>
                    <td>@item.UserEmail</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.PurchaseDate.ToLocalDisplay().ToString("dd/MM/yyyy hh:mm tt")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-card-list"></i> Details
                        </a>
                        @if (item.Status == Real_Estate_App.Models.Transaction.StatusPending)
                        {
                            <form asp-action="Approve" asp-route-id="@item.TransactionId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success"
                                        onclick="return confirm('Approve this purchase? The property will be marked as sold and the buyer will be emailed.');">
                                    <i class="bi bi-check-lg"></i> Approve
                                </button>
                            </form>
                            <button type="button" class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal" data-bs-target="#rejectModal-@item.TransactionId">
                                <i class="bi bi-x-lg"></i> Reject
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="AdminProperties" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-arrow-left" style="vertical-align:middle"></i> Browse Properties
    </a>
</div>

@* Reject confirmation modals. Rendered here, OUTSIDE the table: a modal placed
   inside <tbody> is invalid HTML, so the browser relocates ("foster-parents") it
   and flattens its structure - which made the dialog render oddly and dismiss on
   any click. The Reject buttons above target these by id. *@
@foreach (var item in Model.Where(t => t.Status == Real_Estate_App.Models.Transaction.StatusPending))
{
    <div class="modal fade" id="rejectModal-@item.TransactionId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="Reject" asp-route-id="@item.TransactionId" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Reject Purchase Request #@item.TransactionId</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Reject the request from <strong>@item.BuyerName</strong> for <strong>@item.Property?.PropertyName</strong>?</p>
                    <div class="mb-2">
                        <label class="form-label">Reason (optional, included in the buyer's email)</label>
                        <textarea name="rejectionReason" class="form-control" rows="3" maxlength="500" placeholder="e.g. Buyer did not pass the financial pre-check."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
}
