@model IEnumerable<Transaction>




@if (!Model.Any())
{
    <div class="alert alert-info">
        No transactions have been made yet.
    </div>
}
else
{
    <h1>Admin Transactions Dashboard</h1>
    <hr />
    <table class="table table-striped table-hover border-3 shadow">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th><i class="bi bi-house"></i> Property</th>
                <th><i class="bi bi-geo-alt"></i> Address</th>
                <th><i class="bi bi-person" style="vertical-align:middle"></i> Buyer</th>
                <th><i class="bi bi-envelope" style="vertical-align:middle"></i> Email</th>
                <th><i class="bi bi-currency-dollar" style=""></i> Price</th>
                <th><i class="bi bi-calendar"></i> Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.TransactionId</td>
                    <td>@item.Property?.PropertyName</td>
                    <td>@item.Property?.PropertyAddress</td>
                    <td>@item.BuyerName</td>
                    <td>@item.UserEmail</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.PurchaseDate.ToString("dd/MM/yyyy hh:mm tt")
                        <a asp-action="Details" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-card-list"></i> Details</a>
                    </td>
                </tr>

            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="AdminProperties" asp-action="Index" class="btn btn-primary"><i class="bi bi-arrow-left" style="vertical-align:middle"></i> Browse Properties</a>
</div>
