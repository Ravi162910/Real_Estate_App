@model IEnumerable<Transaction>




@if (!Model.Any())
{
    <div class="alert alert-info">
        No transactions have been made yet.
    </div>
}
else
{
    <h1>Admin Transactions Dashboard</h1>
    <hr />
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Property</th>
                <th>Address</th>
                <th>Buyer</th>
                <th>Email</th>
                <th>Price</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.TransactionId</td>
                    <td>@item.Property?.PropertyName</td>
                    <td>@item.Property?.PropertyAddress</td>
                    <td>@item.BuyerName</td>
                    <td>@item.UserEmail</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.PurchaseDate.ToString("dd/MM/yyyy hh:mm tt")
                        <a asp-action="Details" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-secondary">Details</a>
                    </td>
                </tr>

            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="AdminProperties" asp-action="Index" class="btn btn-primary">Browse Properties</a>
</div>
