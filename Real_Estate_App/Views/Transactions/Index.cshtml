@model IEnumerable<Real_Estate_App.Models.Transaction>

@{
    ViewData["Title"] = "Transaction History";
}

<h1>Transaction History</h1>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">
        No transactions have been made yet.
    </div>
}
else
{
    <p class="text-muted">Showing @Model.Count() transactions</p>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Property</th>
                <th>Address</th>
                <th>Buyer</th>
                <th>Email</th>
                <th>Price</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.TransactionId</td>
                    <td>@item.Property?.PropertyName</td>
                    <td>@item.Property?.PropertyAddress</td>
                    <td>@item.BuyerName</td>
                    <td>@item.UserEmail</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.PurchaseDate.ToString("dd/MM/yyyy hh:mm tt")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="Properties" asp-action="Index" class="btn btn-primary">Browse Properties</a>
</div>
