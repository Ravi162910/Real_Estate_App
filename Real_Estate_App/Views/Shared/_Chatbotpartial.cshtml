<script>
    function toggleChat() {
        const chat = document.getElementById("chat-container");
        chat.classList.toggle("open");
    }

    function addMessage(text, sender) {
        const chatBody = document.getElementById("chat-body");

        const messages = document.createElement("div");
        messages.classList.add("message", sender);
        messages.innerText = text;

        chatBody.appendChild(messages);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    function send() {
        let message = document.getElementById("message").value;

        if (!message) return;

        addMessage(message, "user");

        fetch('/Chatbot/Message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(message)
        })
            .then(res => res.json())
            .then(data => {
                addMessage(data.reply, "bot");

                if (data.action) {
                    const gotopagebutton = document.createElement("button");
                    gotopagebutton.innerText = "click to go to requested page";
                    gotopagebutton.classList.add("btn", "btn-primary", "mt-2")

                    gotopagebutton.onclick = () => {
                        window.location.href = data.action;
                    }

                    document.getElementById("chat-body").appendChild(gotopagebutton)
                }

            });

        document.getElementById("message").value = "";
    }
</script>

<style>
    #chat-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #e95420;
        color: white;
        padding: 12px 16px;
        border-radius: 20px;
        cursor: pointer;
    }

    #chat-container {
        position: fixed;
        bottom: 70px;
        right: 20px;
        width: 300px;
        height: 400px;
        background: white;
        border: 1px solid #ccc;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
    }

    #chat-container {
        display: none;
    }

        #chat-container.open {
            display: flex;
        }

    #chat-header {
        background-color: #aea79f;
        color: black;
        padding: 10px;
        display: flex;
        justify-content: space-between;
    }

    #chat-body {
        flex: 1;
        padding: 10px;
        overflow-y: auto;
    }

    .message {
        margin: 5px 0;
        padding: 8px;
        border-radius: 8px;
        max-width: 80%;
    }

    .user {
        background: #d1e7dd;
        align-self: flex-end;
    }

    .bot {
        background: #f1f1f1;
        align-self: flex-start;
    }

    #chat-input {
        display: flex;
        border-top: 1px solid #ccc;
    }

        #chat-input input {
            flex: 1;
            padding: 8px;
            border: none;
        }

        #chat-input button {
            padding: 8px;
            border: none;
            background: #e95420;
            color: white;
        }
</style>


@if (Context.User.Identity.IsAuthenticated)
{
    <div id="chat-toggle" onclick="toggleChat()">Chat</div>

    <div id="chat-container" class="hidden">
        <div id="chat-header">
            <span style="vertical-align:middle;">Assistant</span>
            <button class="btn btn-sm btn-danger" onclick="toggleChat()">x</button>
        </div>

        <div id="chat-body"></div>

        <div id="chat-input">
            <input type="text" id="message" placeholder="Type a message..." />
            <button onclick="send()">Send</button>
        </div>
    </div>
}
