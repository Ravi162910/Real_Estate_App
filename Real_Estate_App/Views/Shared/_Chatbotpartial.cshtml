<script>
    let chatWelcomed = false;

    function toggleChat() {
        const chat = document.getElementById("chat-container");
        chat.classList.toggle("open");

        // On first open, greet the user and list what they can ask. The text
        // comes from the server's greeting so the menu is defined in one place.
        if (chat.classList.contains("open") && !chatWelcomed) {
            chatWelcomed = true;
            fetch('/Chatbot/Message', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify('hello')
            })
                .then(res => res.json())
                .then(data => addMessage(data.reply, "bot"));
        }
    }

    function addMessage(text, sender) {
        const chatBody = document.getElementById("chat-body");

        const messages = document.createElement("div");
        messages.classList.add("message", sender);
        messages.innerText = text;

        chatBody.appendChild(messages);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    function send() {
        let message = document.getElementById("message").value;

        if (!message) return;

        addMessage(message, "user");

        fetch('/Chatbot/Message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(message)
        })
            .then(res => res.json())
            .then(data => {
                addMessage(data.reply, "bot");

                if (data.action) {
                    const gotopagebutton = document.createElement("button");
                    gotopagebutton.innerText = "click to go to requested page";
                    gotopagebutton.classList.add("btn", "btn-primary", "mt-2")

                    gotopagebutton.onclick = () => {
                        window.location.href = data.action;
                    }

                    document.getElementById("chat-body").appendChild(gotopagebutton)
                }

            });

        document.getElementById("message").value = "";
    }
</script>

<style>
    /* Chat widget themed to match the site (navy + gold). IDs/classes are
       kept identical to the original so the chatbot JS still works. */
    #chat-toggle {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        background: linear-gradient(135deg, #0f1f38 0%, #1f4e8c 100%);
        color: #fff;
        padding: 0.7rem 1.15rem;
        border-radius: 999px;
        cursor: pointer;
        font-family: "Poppins", "Inter", system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 10px 25px rgba(15, 31, 56, 0.30);
        z-index: 1045;
        transition: transform 0.15s ease, box-shadow 0.2s ease;
        user-select: none;
    }

        #chat-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 30px rgba(15, 31, 56, 0.38);
        }

        #chat-toggle .bi {
            color: #d4a24c;
            font-size: 1.1rem;
        }

    #chat-container {
        position: fixed;
        bottom: 5.25rem;
        right: 1.5rem;
        width: 340px;
        height: 460px;
        max-width: calc(100vw - 3rem);
        max-height: calc(100vh - 7rem);
        background: #fff;
        border: 1px solid #e3e8f0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 24px 55px rgba(15, 31, 56, 0.28);
        flex-direction: column;
        z-index: 1045;
    }

    #chat-container {
        display: none;
    }

        #chat-container.open {
            display: flex;
            animation: chatPopIn 0.22s ease;
        }

    @@keyframes chatPopIn {
        from {
            opacity: 0;
            transform: translateY(14px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    #chat-header {
        background: linear-gradient(135deg, #0f1f38 0%, #1f4e8c 100%);
        color: #fff;
        padding: 0.85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: "Poppins", "Inter", system-ui, sans-serif;
        font-weight: 600;
    }

        #chat-header .chat-title {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        #chat-header .chat-title .bi {
            color: #d4a24c;
            font-size: 1.15rem;
        }

        #chat-header .chat-close {
            background: rgba(255, 255, 255, 0.14);
            border: none;
            color: #fff;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            cursor: pointer;
            transition: background 0.15s ease;
            padding: 0;
        }

            #chat-header .chat-close:hover {
                background: rgba(255, 255, 255, 0.28);
            }

    #chat-body {
        flex: 1;
        padding: 0.9rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        background: #f5f7fb;
    }

    .message {
        padding: 0.6rem 0.8rem;
        border-radius: 14px;
        max-width: 82%;
        font-size: 0.9rem;
        line-height: 1.4;
        box-shadow: 0 2px 6px rgba(15, 31, 56, 0.06);
        word-wrap: break-word;
    }

    .user {
        background: linear-gradient(135deg, #1f4e8c 0%, #2a5d9e 100%);
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .bot {
        background: #fff;
        color: #1d2733;
        align-self: flex-start;
        border: 1px solid #e3e8f0;
        border-bottom-left-radius: 4px;
    }

    #chat-input {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem;
        border-top: 1px solid #e3e8f0;
        background: #fff;
    }

        #chat-input input {
            flex: 1;
            padding: 0.55rem 0.8rem;
            border: 1.5px solid #e3e8f0;
            border-radius: 999px;
            outline: none;
            font-size: 0.9rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

            #chat-input input:focus {
                border-color: #1f4e8c;
                box-shadow: 0 0 0 0.15rem rgba(31, 78, 140, 0.18);
            }

        #chat-input button {
            border: none;
            background: linear-gradient(135deg, #0f1f38 0%, #1f4e8c 100%);
            color: #fff;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            transition: transform 0.12s ease, box-shadow 0.2s ease;
        }

            #chat-input button:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 14px rgba(15, 31, 56, 0.25);
            }
</style>


@if (Context.User.Identity.IsAuthenticated)
{
    <div id="chat-toggle" onclick="toggleChat()"><i class="bi bi-chat-dots-fill"></i> Chat</div>

    <div id="chat-container" class="hidden">
        <div id="chat-header">
            <span class="chat-title"><i class="bi bi-robot"></i> Assistant</span>
            <button type="button" class="chat-close" aria-label="Close chat" onclick="toggleChat()"><i class="bi bi-x-lg"></i></button>
        </div>

        <div id="chat-body"></div>

        <div id="chat-input">
            <input type="text" id="message" placeholder="Type a message..." onkeydown="if(event.key==='Enter'){event.preventDefault();send();}" />
            <button type="button" aria-label="Send message" onclick="send()"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>
}
