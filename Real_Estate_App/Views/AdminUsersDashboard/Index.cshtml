@model IEnumerable<User_Data>

<div class="card border-2 mt-4">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">Admin Users Dashboard:</h2>
            </div>
        </div>
    </div>
</div>

<a asp-action="Create" class="btn btn-sm btn-outline-primary mb-4 mt-3"> <i class="bi bi-plus-square-fill"></i> Add a User here</a>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No Users have been added yet.
    </div>
}
else
{
    foreach (var users in Model)
    {
        <div class="card mb-3 border-3 shadow" style="max-width: 540px;">
            <div class="row g-0">
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">
                            @users.First_Name, @users.Last_Name
                            @if (users.IsAdmin)
                            {
                                var roleLabel = string.IsNullOrWhiteSpace(users.AdminRole) ? "Super" : users.AdminRole;
                                <span class="badge bg-primary ms-2">@roleLabel Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-2">User</span>
                            }
                        </h5>
                        <p class="card-text">@users.UserName</p>
                        <p class="card-text">@users.Email</p>
                        <a asp-action="Edit" asp-route-id="@users.UserID" class="btn btn-sm btn-primary"><i class="bi bi-pen"></i> Edit</a>
                        <a asp-action="Details" asp-route-id="@users.UserID" class="btn btn-sm btn-outline-secondary"><i class="bi bi-card-list"></i> Details</a>
                        <a asp-action="Delete" asp-route-id="@users.UserID" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }


}