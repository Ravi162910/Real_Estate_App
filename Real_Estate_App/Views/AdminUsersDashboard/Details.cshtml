@model User_Data

<div class="card shadow border-2 mt-4">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">User Details below:</h2>
            </div>
        </div>
    </div>
</div>

<div class="list-group shadow mb-sm-4">
    <div class="list-group-item">
        <label>User First Name:</label>
        <strong>@Model.First_Name</strong>
    </div>
    <div class="list-group-item">
        <label>User Last Name:</label>
        <strong>@Model.Last_Name</strong>
    </div>
    <div class="list-group-item">
        <label>User Email:</label>
        <strong>@Model.Email</strong>
    </div>
    <div class="list-group-item">
        <label>Username:</label>
        <strong>@Model.UserName</strong>
    </div>
    <div class="list-group-item">
        <label>Role:</label>
        @if (Model.IsAdmin)
        {
            var roleLabel = string.IsNullOrWhiteSpace(Model.AdminRole) ? "Super" : Model.AdminRole;
            <strong>@roleLabel Admin</strong>
        }
        else
        {
            <strong>Regular User</strong>
        }
    </div>
</div>



<a asp-action="Index" asp-route-id="@Model.UserID" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-left"></i> Go back to User List</a>
<a asp-action="Edit" asp-route-id="@Model.UserID" class="btn btn-sm btn-primary"><i class="bi bi-pen"></i> Edit</a>
<a asp-action="Delete" asp-route-id="@Model.UserID" class="btn btn-sm btn-danger"><i class="bi bi-trash" style="font-size: 0.88rem"></i> Delete</a>