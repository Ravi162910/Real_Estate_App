@model User_Data

<div class="card shadow border-2 mt-4">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">User Details below:</h2>
            </div>
        </div>
    </div>
</div>

<div class="list-group shadow mb-sm-4">
    <div class="list-group-item">
        <label>User First Name:</label>
        <strong>@Model.First_Name</strong>
    </div>
    <div class="list-group-item">
        <label>User Last Name:</label>
        <strong>@Model.Last_Name</strong>
    </div>
    <div class="list-group-item">
        <label>User Email:</label>
        <strong>@Model.Email</strong>
    </div>
    <div class="list-group-item">
        <label>Username:</label>
        <strong>@Model.UserName</strong>
    </div>
</div>



<a asp-action="Index" asp-route-id="@Model.UserID" class="btn btn-sm btn-outline-primary">Go back to User List</a>
<a asp-action="Edit" asp-route-id="@Model.UserID" class="btn btn-sm btn-primary">Edit</a>
<a asp-action="Delete" asp-route-id="@Model.UserID" class="btn btn-sm btn-danger">Delete</a>