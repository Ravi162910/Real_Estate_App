@model User_Data

<div class="card border-2 mt-4 mb-3">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">Add a User as Admin:</h2>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="UserID"/>
    <div class="mb-3">
        <label asp-for="First_Name"></label>
        <input asp-for="First_Name" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="First_Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Last_Name"></label>
        <input asp-for="Last_Name" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="Last_Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="UserName"></label>
        <input asp-for="UserName" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control border-3 shadow" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="AdminRole" class="form-label">Account Type</label>
        <select asp-for="AdminRole" class="form-select border-3 shadow">
            <option value="">Regular User</option>
            <option value="Super">Super Admin (full access)</option>
            <option value="Property">Property Admin (properties + viewings)</option>
            <option value="Transaction">Transaction Admin (purchase approvals)</option>
        </select>
        <small class="text-muted d-block">Picking any admin role grants admin access automatically.</small>
        <span asp-validation-for="AdminRole" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary mt-3">
        <i class="bi bi-plus"></i> Create
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary mt-3"><i class="bi bi-x" style="font-size: 1.1rem; vertical-align: middle"></i> Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}