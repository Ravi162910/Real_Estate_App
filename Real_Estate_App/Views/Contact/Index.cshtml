@model ContactRequestViewModel
@{
    ViewData["Title"] = "Contact Us";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <form method="post">

            <div class="card border-2 mt-4 mb-3 shadow">
                <div class="card-header bg-secondary py-4">
                    <div class="row">
                        <div class="col text-center">
                            <h2 class="py-2">Contact Our Team</h2>
                            <p class="mb-0">
                                Run into a problem or have a question? Fill out the form below
                                and we'll get back to you by email.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control border-3 shadow" type="text" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control border-3 shadow" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Problem" class="form-label"></label>
                <select asp-for="Problem" class="form-select border-3 shadow">
                    <option value="">-- Select a topic --</option>
                    @foreach (var option in ContactRequestViewModel.ProblemOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <span asp-validation-for="Problem" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Comments" class="form-label"></label>
                <textarea asp-for="Comments" class="form-control border-3 shadow" rows="5"
                          placeholder="Tell us a bit more about what you need help with..."></textarea>
                <span asp-validation-for="Comments" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary mt-2">Send message</button>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
