@model Viewing

<h1>Add a Viewing as Admin</h1>

<hr />

<form method="post" >
    <div class="form-group">
        <label asp-for="UserID" class="control-label"></label>
        <select asp-for="UserID" class="form-control" asp-items="ViewBag.UserID">
            <option>--Select a User--</option>
        </select>
    </div>
    <div class="form-group, mb-3">
        <label asp-for="PropertyID" class="control-label"></label>
        <select asp-for="PropertyID" class="form-control" asp-items="ViewBag.PropertyID">
            <option>--Select a Property--</option>
        </select>
    </div>
    <div class="form-group, mb-3">
        <label asp-for="Viewing_TimeDate" class="control-label"></label>
        <input asp-for="Viewing_TimeDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="Viewing_TimeDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Create" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}