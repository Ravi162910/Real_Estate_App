@model Property

<div class="card border-2 mt-4">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">Edit property as an Admin:</h2>
            </div>
        </div>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="PropertyId"/>
    <div class="mb-3">
        <label asp-for="PropertyName"></label>
        <input asp-for="PropertyName" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="PropertyName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyAddress"></label>
        <input asp-for="PropertyAddress" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="PropertyAddress" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyBedrooms"></label>
        <input asp-for="PropertyBedrooms" class="form-control border-3 shadow" type="number" />
        <span asp-validation-for="PropertyBedrooms" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyBathrooms"></label>
        <input asp-for="PropertyBathrooms" class="form-control border-3 shadow" type="number" />
        <span asp-validation-for="PropertyBathrooms" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyPets"></label>
        <input asp-for="PropertyPets" class="form-control border-3 shadow" type="number" />
        <span asp-validation-for="PropertyPets" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyGarages"></label>
        <input asp-for="PropertyGarages" class="form-control border-3 shadow" type="number" />
        <span asp-validation-for="PropertyGarages" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ExtendedDescription" class="form-label"></label>
        <textarea asp-for="ExtendedDescription" class="form-control border-3 shadow" rows="4" type="text"></textarea>
        <span asp-validation-for="ExtendedDescription" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control border-3 shadow" type="number" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PropertyType" class="form-label"></label>
        <select asp-for="PropertyType" class="form-select border-3 shadow">
            <option value="">-- Select Type --</option>
            <option value="House">House</option>
            <option value="Apartment">Apartment</option>
            <option value="Flat">Flat</option>
            <option value="Townhouse">Townhouse</option>
            <option value="Studio">Studio</option>
        </select>
        <span asp-validation-for="PropertyType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NearbySchools"></label>
        <input asp-for="NearbySchools" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="NearbySchools" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NearbyShops"></label>
        <input asp-for="NearbyShops" class="form-control border-3 shadow" type="text" />
        <span asp-validation-for="NearbyShops" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IsAvailable"></label>
        <input asp-for="IsAvailable" type="checkbox" />
        <span asp-validation-for="IsAvailable" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-pen"></i> Update
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x" style="font-size: 1.2rem; vertical-align: middle"></i> Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}