@model IEnumerable<Real_Estate_App.Models.Property>

@{
    ViewData["Title"] = "Properties";
    var propertyTypes = ViewData["PropertyTypes"] as List<string> ?? new List<string>();
}

<div class="card border-2 mt-4 mb-3">
    <div class="card-header bg-secondary py-4">
        <div class="row">
            <div class="col text-center">
                <h2 class="py-2">Admin Property Dashboard:</h2>
            </div>
        </div>
    </div>
</div>

<p>
    <a asp-action="Create" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-plus-square-fill"></i>  Add a property
    </a>
</p>

<!-- Search and Filter -->
<div class="card mb-4 border-3 shadow">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <!-- Search bar -->
            <div class="row mb-3">
                <div class="col-md-8">
                    <input type="text" name="searchString" class="form-control"
                           placeholder="Search by name or address..."
                           value="@ViewData["SearchString"]" />
                </div>
                <div class="col-md-4">
                    <select name="propertyType" class="form-select">
                        <option value="">All Property Types</option>
                        @foreach (var type in propertyTypes)
                        {
                            <option value="@type"
                                    selected="@(ViewData["PropertyType"]?.ToString() == type)">
                                @type
                            </option>
                        }
                    </select>
                </div>
            </div>

            <!-- Filters row -->
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Bedrooms</label>
                    <div class="input-group">
                        <input type="number" name="minBedrooms" class="form-control"
                               placeholder="Min" min="0" value="@ViewData["MinBedrooms"]" />
                        <input type="number" name="maxBedrooms" class="form-control"
                               placeholder="Max" min="0" value="@ViewData["MaxBedrooms"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bathrooms</label>
                    <div class="input-group">
                        <input type="number" name="minBathrooms" class="form-control"
                               placeholder="Min" min="0" value="@ViewData["MinBathrooms"]" />
                        <input type="number" name="maxBathrooms" class="form-control"
                               placeholder="Max" min="0" value="@ViewData["MaxBathrooms"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Price</label>
                    <div class="input-group">
                        <input type="number" name="minPrice" class="form-control"
                               placeholder="Min" min="0" step="0.01" value="@ViewData["MinPrice"]" />
                        <input type="number" name="maxPrice" class="form-control"
                               placeholder="Max" min="0" step="0.01" value="@ViewData["MaxPrice"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Other</label>
                    <div class="input-group">
                        <input type="number" name="minGarages" class="form-control"
                               placeholder="Garages" min="0" value="@ViewData["MinGarages"]" />
                        <input type="number" name="minPets" class="form-control"
                               placeholder="Pets" min="0" value="@ViewData["MinPets"]" />
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary"> <i class="bi bi-x" style="font-size: 1.3rem; vertical-align: middle"></i>Clear Filters</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-x text-danger"></i> No properties match your search. Try adjusting your filters.
    </div>
}

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-3 shadow">
                <div class="card-body">
                    <h5 class="card-title">@item.PropertyName</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@item.PropertyType</h6>
                    <p class="card-text">
                        <strong>Address:</strong> @item.PropertyAddress<br />
                        <strong>Bedrooms:</strong> @item.PropertyBedrooms |
                        <strong>Bathrooms:</strong> @item.PropertyBathrooms<br />
                        <strong>Price:</strong> @item.Price.ToString("C")
                    </p>
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn btn-sm btn-primary"> <i class="bi bi-pen"></i> Edit</a>
                    <a asp-action="Details" asp-route-id="@item.PropertyId" class="btn btn-sm btn-dark"><i class="bi bi-card-list"></i> Details</a>
                    <a asp-action="Delete" asp-route-id="@item.PropertyId" class="btn btn-sm btn-danger"> <i class="bi bi-trash"></i> Delete</a>
                </div>
            </div>
        </div>
    }
</div>
